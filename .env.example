# ============================================================
# n8n-ecosystem-unified — Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# --- n8n ---
# Public n8n URL (Caddy handles TLS termination on Proxmox host)
N8N_URL=https://n8n.yourdomain.com
# n8n URL from inside Docker network
N8N_INTERNAL_URL=http://n8n:5678
# Settings → API in n8n UI (generate after first login)
N8N_API_KEY=your_n8n_api_key
# Your public hostname (matches Caddy Caddyfile entry)
N8N_HOST=n8n.yourdomain.com
# Set to "true" to skip Caddy setup (if using external reverse proxy)
SKIP_REVERSE_PROXY=
N8N_PROTOCOL=https
N8N_WEBHOOK_URL=https://n8n.yourdomain.com
# Auto-generated by setup.sh — DO NOT change after first run
# Generate with: openssl rand -hex 32
N8N_ENCRYPTION_KEY=
# Timezone — adjust to your local timezone
TIMEZONE=America/Chicago

# --- Supabase (Self-Hosted) ---
# Kong gateway URL (internal Docker name)
SUPABASE_URL=http://kong:8000
# Public URL for Supabase Studio access from your browser
SUPABASE_PUBLIC_URL=http://127.0.0.1:8000
SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_role_key
# Generate with: openssl rand -hex 32
SUPABASE_JWT_SECRET=your_jwt_secret

# --- PostgreSQL ---
# Strong password required — DO NOT use defaults in production
POSTGRES_PASSWORD=your_strong_postgres_password

# --- Telegram ---
# From @BotFather
TELEGRAM_BOT_TOKEN=your_bot_token
# Your Telegram user/chat ID (use @userinfobot to get it)
TELEGRAM_CHAT_ID=your_chat_id

# --- WhatsApp / Evolution API ---
# Evolution API instance name (set in Evolution dashboard)
EVOLUTION_INSTANCE_NAME=your_instance_name
# Your WhatsApp phone number (digits only, no + or spaces)
WHATSAPP_PHONE=15551234567
# Evolution API base URL (if self-hosted)
EVOLUTION_API_URL=https://evolution.yourdomain.com

# --- LLM Providers ---
# Anthropic (direct)
ANTHROPIC_API_KEY=your_anthropic_key
# OpenRouter (recommended — covers Haiku/Sonnet/Opus tiered routing)
OPENROUTER_API_KEY=your_openrouter_key
# Google AI (for Gemini Flash media analysis in multi-channel router)
GOOGLE_AI_API_KEY=your_google_ai_key

# --- n8n Credential Names (must match workflow JSON exactly) ---
N8N_CREDENTIAL_ANTHROPIC_NAME=Anthropic API
N8N_CREDENTIAL_OPENROUTER_NAME=OpenRouter
N8N_CREDENTIAL_GOOGLE_NAME=Google AI
N8N_CREDENTIAL_TELEGRAM_NAME=Telegram Bot
N8N_CREDENTIAL_POSTGRES_NAME=Supabase Postgres
N8N_CREDENTIAL_GMAIL_NAME=Gmail
N8N_CREDENTIAL_EVOLUTION_NAME=Evolution API

# --- Embeddings (for RAG / vector memory) ---
# Stored in DB (tools_config table) — workflows read from DB, not env
# Supported providers: openai, voyage, ollama
EMBEDDING_PROVIDER=openai
EMBEDDING_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small
# Must match vector column dimension in memory_long (default: 1536)
# EMBEDDING_DIM=1536
# Only for ollama provider:
# OLLAMA_URL=http://localhost:11434

# --- SearXNG ---
# Generate with: openssl rand -hex 32
SEARXNG_SECRET_KEY=your_searxng_secret_key

# --- Optional: Brave Search (SearXNG engine enhancement) ---
BRAVE_API_KEY=your_brave_key

# --- Optional: CTI Stack Integration ---
# MISP
MISP_URL=https://misp.yourdomain.com
MISP_API_KEY=your_misp_api_key
# Wazuh
WAZUH_URL=https://wazuh.yourdomain.com
WAZUH_USER=admin
WAZUH_PASSWORD=your_wazuh_password
# OpenCTI
OPENCTI_URL=https://opencti.yourdomain.com
OPENCTI_TOKEN=your_opencti_token
# TheHive
THEHIVE_URL=https://thehive.yourdomain.com
THEHIVE_API_KEY=your_thehive_api_key
# Cortex
CORTEX_URL=https://cortex.yourdomain.com
CORTEX_API_KEY=your_cortex_api_key

# --- Optional: Nextcloud CalDAV ---
NEXTCLOUD_URL=https://your-nextcloud-instance
NEXTCLOUD_USER=your_user
NEXTCLOUD_PASS=your_password
