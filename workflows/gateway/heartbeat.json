      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 4.2,
      "position": [256, 0],
      "id": "3c6d8e4c-789d-4e7c-b7dd-7ec5f3db823f"
    },
    {
      "parameters": {
        "jsCode": "const tunnels = $input.first().json.tunnels ?? [];\nconst https = tunnels.find(t => t.proto === 'https') ?? tunnels[0];\nif (!https) throw new Error('No ngrok tunnel found');\nconst url = https.public_url;\nreturn [{ json: { url } }];"
      },
      "name": "Extract URL",
      "type": "n8n-nodes-base.code",
