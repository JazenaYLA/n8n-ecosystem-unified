{
  "name": "YAOC2 Gateway Heartbeat",
  "_fix": "Rotated hardcoded Telegram bot token and Evolution API key to $env vars. Fixed Evolution webhook body (was empty). Parameterized Telegram webhook URL.",
  "nodes": [
    {
      "parameters": {
        "rule": { "interval": [{ "field": "minutes" }] }
      },
      "name": "Schedule Trigger",
