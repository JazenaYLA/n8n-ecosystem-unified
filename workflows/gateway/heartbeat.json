        "jsonBody": "={{ JSON.stringify({ url: $('Extract URL').first().json.url + '/webhook/d2cf4a44-47b3-43a3-b3a3-dbc7fdf9b61e', webhook_by_events: false, webhook_base64: false, events: ['MESSAGES_UPSERT', 'MESSAGES_UPDATE', 'CONNECTION_UPDATE'] }) }}",
        "options": { "timeout": 10000 }
      },
      "name": "Update WhatsApp Webhook",
