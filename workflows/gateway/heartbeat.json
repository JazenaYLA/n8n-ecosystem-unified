        "sendHeaders": true,
        "headerParameters": {
          "parameters": [{
            "name": "apikey",
            "value": "={{ $env.EVOLUTION_API_KEY }}"
          }, {
            "name": "Content-Type",
            "value": "application/json"
          }]
