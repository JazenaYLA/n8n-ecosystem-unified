      "type": "@n8n/n8n-nodes-langchain.agent",
      "position": [720, 160],
      "typeVersion": 3.1
    },
    {
      "parameters": {
        "model": "anthropic/claude-opus-4-5",
        "options": { "maxTokens": 8192, "temperature": 0.7 }
      },
      "id": "llm-opus",
      "name": "LLM: Claude Opus (OpenRouter)",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenRouter",
      "position": [720, 0],
      "typeVersion": 1,
