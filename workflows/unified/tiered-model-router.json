{
  "name": "[UNIFIED] Tiered Model Router (Sub-Agent Runner)",
  "_unified_version": "1.1.0",
  "_sync_note": "Synced from live brain LXC 2026-03-24. Adds Window Buffer Memory and Gateway Tools (MCP) nodes present in live instance but missing from v1.0.0. MCP JWT rotated to placeholder — set GATEWAY_MCP_TOKEN env var.",
  "_doc": "Routes incoming tasks to Haiku/Sonnet/Opus based on complexity heuristic. Input: {agent, task, context, complexity}. Output: {result, tier, complexity}. Memory is shared Window Buffer — all three agents share the same session window.",
  "nodes": [
    {
      "parameters": { "inputSource": "passthrough" },
      "id": "wf-trigger",
      "name": "Workflow Trigger",
      "type": "n8n-nodes-base.executeWorkflowTrigger",
      "position": [0, 0],
      "typeVersion": 1.1
    },
    {
      "parameters": {
        "jsCode": "const raw = $input.first().json;\nconst agent = raw.agent || 'general';\nconst task = raw.task || raw.userMessage || '';\nconst context = raw.context || '';\nconst explicitComplexity = raw.complexity;\n\nlet complexity = explicitComplexity;\nif (!complexity) {\n  if (/strateg|architect|design|plan|reason|analyze|compar|synthesiz|research|investigat|why|how.{0,20}work/i.test(task)) {\n    complexity = 8;\n  } else if (/summar|explain|draft|write|creat|list|find|search|lookup|format|translat/i.test(task)) {\n    complexity = 5;\n  } else {\n    complexity = 3;\n  }\n}\ncomplexity = Math.max(1, Math.min(10, Number(complexity)));\n\nconst tier = complexity <= 3 ? 'haiku' : complexity <= 7 ? 'sonnet' : 'opus';\nconst model = {\n  haiku: 'anthropic/claude-haiku-4.5',\n  sonnet: 'anthropic/claude-sonnet-4.5',\n  opus: 'anthropic/claude-opus-4-5'\n}[tier];\n\nconst systemPrompt = `You are a specialized ${agent} agent. Be direct, thorough, and precise. Respond in the same language as the task.\n\nContext from the user's conversation:\n${context}`;\n\nreturn [{ json: { agent, task, context, complexity, tier, model, systemPrompt } }];"
      },
      "id": "complexity-router",
      "name": "Complexity Router",
      "type": "n8n-nodes-base.code",
      "position": [240, 0],
      "typeVersion": 2
    },
    {
      "parameters": {
        "rules": {
          "values": [
            {
              "conditions": {
                "options": { "version": 3, "caseSensitive": true, "typeValidation": "strict" },
                "combinator": "and",
                "conditions": [{ "id": "tier-haiku", "operator": { "type": "string", "operation": "equals" }, "leftValue": "={{ $json.tier }}", "rightValue": "haiku" }]
              },
              "renameOutput": true,
              "outputKey": "haiku"
            },
            {
              "conditions": {
                "options": { "version": 3, "caseSensitive": true, "typeValidation": "strict" },
                "combinator": "and",
                "conditions": [{ "id": "tier-sonnet", "operator": { "type": "string", "operation": "equals" }, "leftValue": "={{ $json.tier }}", "rightValue": "sonnet" }]
              },
              "renameOutput": true,
              "outputKey": "sonnet"
            },
            {
              "conditions": {
                "options": { "version": 3, "caseSensitive": true, "typeValidation": "strict" },
                "combinator": "and",
                "conditions": [{ "id": "tier-opus", "operator": { "type": "string", "operation": "equals" }, "leftValue": "={{ $json.tier }}", "rightValue": "opus" }]
              },
              "renameOutput": true,
              "outputKey": "opus"
            }
          ]
        },
        "options": {}
      },
      "id": "tier-switch",
      "name": "Tier Switch",
      "type": "n8n-nodes-base.switch",
      "position": [480, 0],
      "typeVersion": 3.4
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $('Complexity Router').first().json.task }}",
        "options": {
          "systemMessage": "={{ $('Complexity Router').first().json.systemPrompt }}",
          "maxIterations": 5
        }
      },
      "id": "agent-haiku",
      "name": "Worker Agent 1 (Haiku)",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "position": [720, -160],
      "typeVersion": 3.1
    },
    {
      "parameters": {
        "model": "anthropic/claude-haiku-4.5",
        "options": { "maxTokens": 2048, "temperature": 0.5 }
      },
      "id": "llm-haiku",
      "name": "LLM: Claude Haiku (OpenRouter)",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenRouter",
      "position": [720, -320],
      "typeVersion": 1,
      "credentials": {
        "openRouterApi": {
          "id": "A5zblswmipMC8LaE",
          "name": "OpenRouter"
        }
      }
    },
    {
      "parameters": {
        "promptType": "define",
        "text": "={{ $('Complexity Router').first().json.task }}",
        "options": {
          "systemMessage": "={{ $('Complexity Router').first().json.systemPrompt }}",
          "maxIterations": 8
        }
      },
      "id": "agent-sonnet",
      "name": "Worker Agent 2 (Sonnet)",
      "type": "@n8n/n8n-nodes-langchain.agent",
      "position": [720, 0],
      "typeVersion": 3.1
    },
    {
      "parameters": {
        "model": "anthropic/claude-sonnet-4.5",
        "options": { "maxTokens": 4096, "temperature": 0.7 }
      },
      "id": "llm-sonnet",
      "name": "LLM: Claude Sonnet (OpenRouter)",
      "type": "@n8n/n8n-nodes-langchain.lmChatOpenRouter",
      "position": [720, -160],
      "typeVersion": 1,
      "credentials": {
        "openRouterApi": {
          "id": "A5zblswmipMC8LaE",
