        "jsCode": "let q; try { q = JSON.parse(query).q || query; } catch(e) { q = query; }\nconst r = await helpers.httpRequest({ method:'GET', url:`http://searxng:8080/search?q=${encodeURIComponent(q)}&format=json`, headers:{Accept:'application/json'} });\nreturn (r.results||[]).slice(0,5).map(x=>`${x.title}\\n${x.url}\\n${x.content||''}`).join('\\n\\n') || 'No results.';"
