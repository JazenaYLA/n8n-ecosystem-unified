    {
      "parameters": {
        "description": "Search the web. Input: query string.",
        "jsCode": "let q; try { q = JSON.parse(query).q || query; } catch(e) { q = query; }\nconst r = await helpers.httpRequest({ method:'GET', url:`http://searxng:8080/search?q=${encodeURIComponent(q)}&format=json`, headers:{Accept:'application/json'} });\nreturn (r.results||[]).slice(0,5).map(x=>`${x.title}\\n${x.url}\\n${x.content||''}`).join('\\n\\n') || 'No results.';"
      },
      "id": "tool-web-search-opus",
      "name": "Web Search (Opus)",
      "type": "@n8n/n8n-nodes-langchain.toolCode",
      "position": [960, 0],
      "typeVersion": 1.2
    },
    {
      "parameters": {
        "jsCode": "const haiku = (() => { try { return $('Worker Agent 1 (Haiku)').first()?.json?.output; } catch(e) { return null; } })();\nconst sonnet = (() => { try { return $('Worker Agent 2 (Sonnet)').first()?.json?.output; } catch(e) { return null; } })();\nconst opus = (() => { try { return $('Worker Agent 3 (Opus)').first()?.json?.output; } catch(e) { return null; } })();\nconst result = opus || sonnet || haiku || 'No output produced.';\nconst tier = $('Complexity Router').first().json.tier;\nconst complexity = $('Complexity Router').first().json.complexity;\nreturn [{ json: { output: result, result, tier, complexity } }];"
      },
      "_fix_note": "Added output: result alias so callers referencing $json.output (multi-channel-router reply nodes) work without remapping.",
      "id": "collect-result",
      "name": "Collect Result",
      "type": "n8n-nodes-base.code",
      "position": [1200, 0],
